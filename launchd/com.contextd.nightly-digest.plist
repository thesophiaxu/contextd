<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.contextd.nightly-digest</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/amit/contextd/scripts/nightly-digest.py</string>
